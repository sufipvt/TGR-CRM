<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Booking Receipt TG-<%= String(booking._id).slice(-8).toUpperCase() %> — TrueGrowth CRM</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    @page { size: A4; margin: 20mm; }
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', Arial, sans-serif; }
    body { background: #f4f7fe; color: #111827; padding: 24px 12px; }
    .receipt { max-width: 720px; margin: 0 auto; background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 40px; }
    .head { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #1a56db; padding-bottom: 20px; margin-bottom: 24px; }
    .brand { font-size: 22px; font-weight: 700; color: #1a56db; }
    .brand-sub { font-size: 12px; color: #6b7280; margin-top: 2px; }
    .ref { text-align: right; }
    .ref-num { font-size: 18px; font-weight: 700; }
    .ref-date { font-size: 13px; color: #6b7280; margin-top: 2px; }
    h1 { font-size: 16px; text-transform: uppercase; letter-spacing: 1px; color: #374151; margin-bottom: 16px; }
    .grid { display: flex; flex-wrap: wrap; gap: 24px; margin-bottom: 24px; }
    .grid > div { flex: 1 1 200px; }
    .label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #9ca3af; margin-bottom: 2px; }
    .value { font-size: 14px; font-weight: 500; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
    th { text-align: left; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #6b7280; padding: 8px 10px; background: #f8fafc; border-bottom: 1px solid #e5e7eb; }
    td { font-size: 13px; padding: 9px 10px; border-bottom: 1px solid #f1f5f9; }
    .totals { max-width: 320px; margin-left: auto; margin-bottom: 24px; }
    .totals .row { display: flex; justify-content: space-between; padding: 6px 0; font-size: 14px; }
    .totals .row.grand { border-top: 2px solid #111827; font-weight: 700; font-size: 15px; padding-top: 10px; margin-top: 6px; }
    .balance-due { color: #dc2626; }
    .balance-clear { color: #059669; }
    .footer { border-top: 1px solid #e5e7eb; padding-top: 16px; font-size: 12px; color: #9ca3af; text-align: center; }
    .print-btn { display: block; margin: 20px auto 0; background: #4f46e5; color: #fff; border: none; border-radius: 8px; padding: 12px 32px; font-size: 15px; font-weight: 600; cursor: pointer; }
    .print-btn:hover { background: #4338ca; }
    @media print {
      body { background: #fff; padding: 0; }
      .receipt { border: none; border-radius: 0; padding: 0; max-width: none; }
      button { display: none; }
    }
  </style>
</head>
<body>
  <main class="receipt">
    <div class="head">
      <div>
        <div class="brand"><%= settings.company_name %></div>
        <div class="brand-sub">Real Estate Sales &amp; Advisory</div>
      </div>
      <div class="ref">
        <div class="ref-num">TG-<%= String(booking._id).slice(-8).toUpperCase() %></div>
        <div class="ref-date"><%= new Date(booking.booking_date).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %></div>
      </div>
    </div>

    <h1>Booking Receipt</h1>

    <div class="grid">
      <div>
        <div class="label">Customer</div>
        <div class="value"><%= booking.lead_id ? booking.lead_id.name : '—' %></div>
        <div class="value" style="font-weight:400;color:#6b7280;font-size:13px;"><%= booking.lead_id ? booking.lead_id.phone : '' %><%= booking.lead_id && booking.lead_id.email ? ' · ' + booking.lead_id.email : '' %></div>
      </div>
      <div>
        <div class="label">Project</div>
        <div class="value"><%= booking.project_id ? booking.project_id.name : '—' %></div>
        <div class="value" style="font-weight:400;color:#6b7280;font-size:13px;"><%= booking.project_id ? [booking.project_id.location, booking.project_id.city].filter(Boolean).join(', ') : '' %></div>
      </div>
      <div>
        <div class="label">Unit</div>
        <div class="value"><%= booking.unit_id ? booking.unit_id.unit_number : '—' %></div>
        <div class="value" style="font-weight:400;color:#6b7280;font-size:13px;">
          <%= booking.unit_id && booking.unit_id.bhk ? booking.unit_id.bhk : '' %><%= booking.unit_id && booking.unit_id.area_sqft ? ' · ' + booking.unit_id.area_sqft + ' sqft' : '' %>
        </div>
      </div>
      <div>
        <div class="label">Sales Executive</div>
        <div class="value"><%= booking.closer_id ? booking.closer_id.full_name : '—' %></div>
        <div class="value" style="font-weight:400;color:#6b7280;font-size:13px;">Status: <%= booking.status %></div>
      </div>
    </div>

    <h1>Payment History</h1>
    <table>
      <thead>
        <tr><th>Date</th><th>Method</th><th>Reference</th><th style="text-align:right;">Amount</th></tr>
      </thead>
      <tbody>
        <% if (!payments.length) { %>
          <tr><td colspan="4" style="color:#9ca3af;">No payments recorded yet.</td></tr>
        <% } %>
        <% payments.forEach(p => { %>
          <tr>
            <td><%= new Date(p.payment_date).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
            <td><%= p.method || '—' %></td>
            <td><%= p.reference || '—' %></td>
            <td style="text-align:right;font-weight:500;"><%= formatMoney(p.amount) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <div class="totals">
      <div class="row"><span>Sale Value</span><span><%= formatMoney(booking.sale_value) %></span></div>
      <div class="row"><span>Booking Amount</span><span><%= formatMoney(booking.booking_amount) %></span></div>
      <div class="row"><span>Amount Paid</span><span class="balance-clear"><%= formatMoney(amount_paid) %></span></div>
      <div class="row grand">
        <span>Balance Outstanding</span>
        <span class="<%= (booking.sale_value - amount_paid) > 0 ? 'balance-due' : 'balance-clear' %>"><%= formatMoney(booking.sale_value - amount_paid) %></span>
      </div>
    </div>

    <div class="footer">This is a computer-generated receipt. &mdash; TrueGrowth CRM</div>
    <button class="print-btn" onclick="window.print()">Print / Save PDF</button>
  </main>
</body>
</html>
